{
  "name": "InkCalibur",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate" : "pnpm --filter @repo/db exec prisma generate",
    "start:frontend": "cd apps/frontend && pnpm run start && cd ../..",
    "start:http-server": "cd apps/http-server && pnpm run start && cd ../..",
    "start:ws-server": "cd apps/ws-server && pnpm run start && cd ../.."
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
